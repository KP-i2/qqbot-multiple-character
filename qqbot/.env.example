HOST=0.0.0.0
PORT=8080
COMMAND_START=["/"]
COMMAND_SEP=[" "]
SUPERUSERS=[]

# DeepSeek API（必填，前往 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI API（可选，主选模型，失败时回退 DeepSeek）
OPENAI_ENABLED=false
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://your-openai-proxy.com
OPENAI_MODEL=gpt-5.5

# OneBot v11 连接（NapCat / Lagrange 等）
ONEBOT_ACCESS_TOKEN=
ONEBOT_HOST=127.0.0.1
ONEBOT_PORT=3001

# Bot 活跃时间（小时，0-23）
ACTIVE_HOURS_START=0
ACTIVE_HOURS_END=23

# 管理员 QQ 号
ADMIN_QQ=your-qq-number

# Dashboard 访问 Token
DASHBOARD_TOKEN=your-dashboard-token

# 默认角色 Skill（启动时加载）
DEFAULT_SKILL=761

# Web Search（联网搜索开关）
WEB_SEARCH_ENABLED=true
