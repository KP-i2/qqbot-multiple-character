HOST=0.0.0.0
PORT=8080                               # NoneBot2 监听端口（NapCat 连接到此端口）
COMMAND_START=["/"]
COMMAND_SEP=[" "]
SUPERUSERS=[]

# DeepSeek API（必填，前往 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI API（可选，主选模型，失败时回退 DeepSeek）
OPENAI_ENABLED=false
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://your-openai-proxy.com
OPENAI_MODEL=gpt-5.5

# Bot 活跃时间（小时，0-23）
ACTIVE_HOURS_START=0
ACTIVE_HOURS_END=23

# 管理员 QQ 号
ADMIN_QQ=your-qq-number

# Dashboard 访问 Token
DASHBOARD_TOKEN=your-dashboard-token

# 默认角色 Skill（启动时加载）
DEFAULT_SKILL=761

# Web Search（联网搜索开关）
WEB_SEARCH_ENABLED=true

# ── 运行时参数（也可通过 Dashboard「参数设置」动态调整） ──
# STREAM_ENABLED=true              # 流式输出开关
# STREAM_FLUSH_CHARS=60            # 流式累积字符数阈值
# STREAM_FLUSH_INTERVAL=8.0        # 流式发送间隔（秒）
# STREAM_FLUSH_MIN_CHARS=80        # 最小累积字符数
# STREAM_MAX_FLUSH_SIZE=300        # 单次最大发送字符数
# MAX_HISTORY_ROUNDS=40            # 最大对话轮数
# HISTORY_TTL_HOURS=6              # 对话历史过期时间（小时）
# HISTORY_SAVE_INTERVAL=60         # 历史持久化间隔（秒）
# THINKING_TIMER_SECONDS=5         # "思考中"提示延迟（秒）
# MULTI_TURN_ENABLED=true          # 多轮对话开关
